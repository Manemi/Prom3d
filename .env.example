# Prom3D Ads Agent — Змінні середовища
# ═══════════════════════════════════════
# Скопіюй цей файл як .env і заповни

# Google Ads
ADS_CLIENT_SECRET=вставити_client_secret_тут
ADS_REFRESH_TOKEN=вставити_після_авторизації

# GA4 — шлях до JSON файлу сервіс-акаунту
GA4_KEY_FILE=./service-account.json

# Порт сервера
PORT=3000
